[Unit]
Description=QuizBot (Java)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/quizbot
ExecStart=/usr/bin/java -jar /opt/quizbot/quizbot.jar
Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal
SyslogIdentifier=quizbot

[Install]
WantedBy=multi-user.target
