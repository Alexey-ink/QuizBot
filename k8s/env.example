# Скопируй в Jenkins Secret File credential "env-file-quizbot" (формат KEY=VALUE).
# Используется и контейнером postgres, и quizbot (см. application.properties).
# Не добавляй сюда HTTP_PROXY/HTTPS_PROXY/ALL_PROXY/SOCKS_*/JAVA_TOOL_OPTIONS с прокси — JDBC к postgres и внешние API уйдут в SOCKS и упадут.
# В deployment для quizbot заданы JAVA_TOOL_OPTIONS (отключение SOCKS) и NO_PROXY; не дублируй их в секрете.

POSTGRES_USER=quizbot
POSTGRES_PASSWORD=change_me

# QuizBot → Spring (имена как в application.properties). Без этой строки Spring уйдёт на localhost:5432 внутри пода.
POSTGRES_URL=jdbc:postgresql://postgres:5432/quizbot

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=@tlgrm_quiz_bot

# true = registerBot при старте (нужен HTTPS до api.telegram.org). В k8s deployment по умолчанию false через env.
# QUIZBOT_TELEGRAM_REGISTER_ON_STARTUP=false

# Опционально
# ADMIN_DEFAULT_LOGIN=admin
# ADMIN_DEFAULT_PASSWORD=
# ADMIN_DEFAULT_TELEGRAM_ID=
