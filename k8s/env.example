# Скопируй в Jenkins Secret File credential "env-file-quizbot" (формат KEY=VALUE).
# Используется и контейнером postgres, и quizbot (см. application.properties).

POSTGRES_USER=quizbot
POSTGRES_PASSWORD=change_me

# QuizBot → Spring (имена как в application.properties)
POSTGRES_URL=jdbc:postgresql://postgres:5432/quizbot

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=@tlgrm_quiz_bot

# Опционально
# ADMIN_DEFAULT_LOGIN=admin
# ADMIN_DEFAULT_PASSWORD=
# ADMIN_DEFAULT_TELEGRAM_ID=
